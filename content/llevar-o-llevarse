<script>
(function () {
  var submitBtn = document.getElementById('submitBtn');
  var scoreCard = document.getElementById('scoreCard');
  var scoreNum = document.getElementById('scoreNum');
  var retryBtn = document.getElementById('retryBtn');
  var unansweredHint = document.getElementById('unansweredHint');

  function normalize(str) {
    return str.toLowerCase().trim()
      .replace(/á/g,'a').replace(/é/g,'e').replace(/í/g,'i').replace(/ó/g,'o').replace(/ú/g,'u')
      .replace(/\s+/g, ' ');
  }

  // multiple-choice buttons: click to select
  document.querySelectorAll('.item[data-qid]').forEach(function (item) {
    var opts = item.querySelectorAll('.opt');
    if (!opts.length) return;
    opts.forEach(function (btn) {
      btn.addEventListener('click', function () {
        opts.forEach(function (o) { o.classList.remove('selected'); });
        btn.classList.add('selected');
        item.dataset.userVal = btn.dataset.val;
      });
    });
  });

  function gradeAll() {
    var total = 0, correct = 0;
    var anyUnanswered = false;

    // multiple choice
    document.querySelectorAll('.item[data-qid]').forEach(function (item) {
      var opts = item.querySelectorAll('.opt');
      if (!opts.length) return;
      total++;
      var userVal = item.dataset.userVal;
      var correctBtn = item.querySelector('.opt[data-correct="true"]');
      if (!userVal) anyUnanswered = true;
      opts.forEach(function (o) { o.disabled = true; });
      if (correctBtn) correctBtn.classList.add('show-correct');
      if (correctBtn && userVal === correctBtn.dataset.val) {
        correct++;
        item.classList.add('correct');
      } else {
        item.classList.add('incorrect');
        if (userVal) {
          opts.forEach(function (o) {
            if (o.dataset.val === userVal) o.classList.add('show-wrong');
          });
        }
      }
      var explainEl = item.querySelector('.explain');
      if (explainEl) explainEl.classList.add('show');
    });

    // fill-in-the-blank
    document.querySelectorAll('.blank-input').forEach(function (input) {
      total++;
      var item = input.closest('.item');
      var userVal = normalize(input.value || '');
      var correctVal = normalize(input.dataset.answer);
      var isCorrect = (userVal === correctVal);
      if (!userVal) anyUnanswered = true;
      input.disabled = true;
      if (isCorrect) {
        correct++;
        input.classList.add('correct-input');
        if (item) item.classList.add('correct');
      } else {
        input.classList.add('incorrect-input');
        if (item) item.classList.add('incorrect');
      }
      if (item) {
        var explainEl = item.querySelector('.explain');
        if (explainEl) explainEl.classList.add('show');
      }
    });

    // relational dropdowns
    document.querySelectorAll('.rel-select').forEach(function (sel) {
      total++;
      var correctVal = sel.dataset.answer;
      sel.disabled = true;
      if (!sel.value) anyUnanswered = true;
      if (sel.value === correctVal) {
        correct++;
        sel.classList.add('correct-input');
      } else {
        sel.classList.add('incorrect-input');
      }
    });

    scoreNum.textContent = correct + ' / ' + total;
    scoreCard.classList.add('show');
    submitBtn.style.display = 'none';
    unansweredHint.classList.remove('show');
    scoreCard.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }

  submitBtn.addEventListener('click', gradeAll);

  retryBtn.addEventListener('click', function () {
    location.reload();
  });
})();
</script>
